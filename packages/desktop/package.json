{
  "name": "@event-editor/desktop",
  "version": "0.0.34",
  "private": true,
  "description": "Bento Box desktop app",
  "author": "Spark",
  "main": "main.js",
  "scripts": {
    "test": "node --test test/*.mjs",
    "dev": "EE_DESKTOP_DEV_URL=http://localhost:3000 electron .",
    "assemble": "node scripts/assemble-server.mjs",
    "dist": "npm run -w @event-editor/core build && npm run -w @event-editor/web build && npm run assemble && node scripts/rebuild-native.mjs && electron-builder"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "sg.spark.eventeditor",
    "productName": "Bento Box",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**"
    ],
    "extraResources": [
      {
        "from": "build/server",
        "to": "server"
      },
      {
        "from": "build/preset.env",
        "to": "preset.env"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/icon.ico"
    }
  }
}
